{
  "regions": ["fra1"],
  "functions": {
    "api/index.js": {
      "regions": [
        "fra1"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/module/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/((?!.*\\.[a-zA-Z0-9]+$).*)",
      "destination": "/index.html"
    }
  ]
}

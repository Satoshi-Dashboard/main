# .env.example — copy to .env and fill in values
# Never commit .env to source control

# ── Server ──────────────────────────────────────────────────────────────────
API_PORT=8787
API_HOST=0.0.0.0
API_PROXY_TARGET=http://127.0.0.1:8787
REFRESH_API_TOKEN=change-me
GENERAL_API_RATE_LIMIT_MAX=240
PUBLIC_API_RATE_LIMIT_MAX=60
REFRESH_API_RATE_LIMIT_MAX=10
VISITOR_COUNTER_SALT=change-me

# ── Optional cache (Vercel KV / Upstash Redis) ───────────────────────────────
CACHE_KEY_PREFIX=satoshi-dashboard:v1
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Optional web scraper proxy ───────────────────────────────────────────────
SCRAPER_BASE_URL=https://api.zatobox.io

# ── Optional Bitcoin Core RPC via Tor (for real S04 mempool data) ────────────
BITCOIN_RPC_ONION=
BITCOIN_RPC_PORT=9332
BITCOIN_RPC_USER=
BITCOIN_RPC_PASS=
BITCOIN_TOR_SOCKS_PORT=9050

# ── Google Search Console (scripts/gsc-inspect.js + scripts/gsc-sitemap.js) ──
# Full JSON of the service account key downloaded from Google Cloud Console.
# The service account must be granted Owner access in Search Console.
# Paste the entire JSON as a single line (remove line breaks).
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# The GSC property URL — must match exactly as registered in Search Console.
# URL prefix property:  https://satoshidashboard.com/
# Domain property:      sc-domain:satoshidashboard.com
GOOGLE_SITE_URL=https://satoshidashboard.com/

# ── PageSpeed Insights (scripts/pagespeed.js) ────────────────────────────────
# Optional: Google Cloud API key with PageSpeed Insights API enabled.
# Without this, anonymous quota applies (25,000 req/day).
PAGESPEED_API_KEY=

# Production base URL for PSI and PageSpeed tests (no trailing slash)
PROD_URL=https://satoshidashboard.com

# ── Lighthouse CI (optional) ─────────────────────────────────────────────────
# GitHub App token for LHCI to post PR status checks and inline annotations.
# Install at https://github.com/apps/lighthouse-ci
LHCI_GITHUB_APP_TOKEN=

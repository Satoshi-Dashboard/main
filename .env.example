API_PORT=8787
API_HOST=0.0.0.0
API_PROXY_TARGET=http://127.0.0.1:8787

# Required in production if you want refresh endpoints enabled.
REFRESH_API_TOKEN=change-me

# Optional privacy salt for anonymous visitor IDs.
VISITOR_COUNTER_SALT=change-me

# Optional shared cache namespace.
CACHE_KEY_PREFIX=satoshi-dashboard:v1

# Optional shared KV (recommended for Vercel multi-instance consistency).
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional scraper proxy.
SCRAPER_BASE_URL=https://api.zatobox.io

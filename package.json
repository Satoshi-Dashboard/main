{
  "name": "satoshi-dashboard",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "node --env-file-if-exists=.env server/index.js",
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:ui\"",
    "dev:ui": "vite",
    "dev:api": "node --env-file-if-exists=.env server/index.js",
    "build": "vite build",
    "check:security": "node scripts/check-security.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:vercel-local": "vite preview --host 0.0.0.0",
    "start:api": "node --env-file-if-exists=.env server/index.js",
    "lhci": "lhci autorun --config=.lighthouserc.cjs",
    "lhci:sitemap": "node scripts/gsc-sitemap.js",
    "lhci:inspect": "node scripts/gsc-inspect.js",
    "pagespeed": "node scripts/pagespeed.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "leaflet": "^1.9.4",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.576.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-animated-counter": "^1.8.4",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "socks-proxy-agent": "^8.0.5",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@lhci/cli": "^0.15.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "googleapis": "^171.4.0",
    "jsdom": "^27.0.1",
    "supertest": "^7.2.2",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
